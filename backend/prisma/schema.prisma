generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Site {
  id               String   @id @default(cuid())
  name             String
  locationLabel    String
  latitude         Float
  longitude        Float
  areaHa           Float
  cropType         String
  environment      String
  irrigationMethod String
  soilType         String
  connectedProbes  Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  irrigationLogs          IrrigationLog[]
  recommendationSnapshots RecommendationSnapshot[]
  weatherCache            WeatherCache?
  sensorReadings          SensorReading[]
}

model IrrigationLog {
  id            String   @id @default(cuid())
  siteId        String
  appliedMm     Float
  appliedLitres Float
  performedAt   DateTime
  notes         String?
  createdAt     DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

model SensorReading {
  id          String   @id @default(cuid())
  siteId      String
  moisturePct Float
  source      String // manual, probe, calibration
  recordedAt  DateTime
  notes       String?
  createdAt   DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

model RecommendationSnapshot {
  id                String   @id @default(cuid())
  siteId            String
  headline          String
  actionLabel       String
  startBy           String
  urgency           String
  riskBand          String
  recommendedMm     Float
  recommendedLitres Float
  modelScore        Int
  summary           String
  reasonsJson       String
  capturedAt        DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

model WeatherCache {
  id           String   @id @default(cuid())
  siteId       String   @unique
  responseJson String
  fetchedAt    DateTime @default(now())
  expiresAt    DateTime

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}
